<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Ticket Booking</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body{
            background:#111827;
            color:white;
        }

        /* Header */

        header{
            background:#000;
            padding:15px 40px;
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        header h1{
            color:#ff3c3c;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin-left:20px;
            font-size:18px;
        }

        nav a:hover{
            color:#ff3c3c;
        }

        /* Hero Section */

        .hero{
            height:350px;
            background:url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba');
            background-size:cover;
            background-position:center;
            display:flex;
            justify-content:center;
            align-items:center;
            text-align:center;
        }

        .hero h2{
            font-size:45px;
            margin-bottom:10px;
        }

        .hero p{
            font-size:20px;
        }

        /* Movies */

        .movies{
            padding:50px 20px;
            text-align:center;
        }

        .movies h2{
            margin-bottom:40px;
            color:#ff3c3c;
            font-size:35px;
        }

        .movie-container{
            display:flex;
            justify-content:center;
            gap:25px;
            flex-wrap:wrap;
        }

        .movie-card{
            background:#1f2937;
            width:280px;
            border-radius:10px;
            overflow:hidden;
            box-shadow:0 0 10px rgba(0,0,0,0.5);
        }

        .movie-card img{
            width:100%;
            height:350px;
            object-fit:cover;
        }

        .movie-card h3{
            margin:15px 0 10px;
        }

        .movie-card p{
            padding:0 15px 15px;
            color:#d1d5db;
        }

        .btn{
            display:inline-block;
            margin-bottom:20px;
            padding:10px 20px;
            background:#ff3c3c;
            color:white;
            text-decoration:none;
            border-radius:5px;
        }

        .btn:hover{
            background:#d62828;
        }

        /* Booking Form */

        .booking{
            width:400px;
            margin:50px auto;
            background:#1f2937;
            padding:30px;
            border-radius:10px;
        }

        .booking h2{
            text-align:center;
            margin-bottom:20px;
            color:#ff3c3c;
        }

        .booking input,
        .booking select{
            width:100%;
            padding:12px;
            margin-bottom:15px;
            border:none;
            border-radius:5px;
        }

        .booking button{
            width:100%;
            border:none;
            cursor:pointer;
        }

        /* Footer */

        footer{
            background:#000;
            text-align:center;
            padding:15px;
            margin-top:40px;
        }

    </style>
</head>

<body>

    <!-- Header -->

    <header>
        <h1>MovieZone</h1>

        <nav>
            <a href="#">Home</a>
            <a href="#">Movies</a>
            <a href="#">Offers</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Hero -->

    <section class="hero">
        <div>
            <h2>Book Your Movie Tickets Online</h2>
            <p>Fast • Easy • Secure</p>
        </div>
    </section>

    <!-- Movies -->

    <section class="movies">

        <h2>Now Showing</h2>

        <div class="movie-container">

            <div class="movie-card">
                <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c">

                <h3>Avengers</h3>

                <p>Action | Adventure | Sci-Fi</p>

                <a href="#" class="btn">Book Now</a>
            </div>

            <div class="movie-card">
                <img src="https://images.unsplash.com/photo-1536440136628-849c177e76a1">

                <h3>Batman</h3>

                <p>Action | Thriller</p>

                <a href="#" class="btn">Book Now</a>
            </div>

            <div class="movie-card">
                <img src="https://images.unsplash.com/photo-1485846234645-a62644f84728">

                <h3>Spider Man</h3>

                <p>Adventure | Fantasy</p>

                <a href="#" class="btn">Book Now</a>
            </div>

        </div>

    </section>

    <!-- Booking Form -->

    <section class="booking">

        <h2>Book Ticket</h2>

        <form>

            <input type="text" placeholder="Enter Your Name" required>

            <select required>
                <option>Select Movie</option>
                <option>Avengers</option>
                <option>Batman</option>
                <option>Spider Man</option>
            </select>

            <input type="date" required>

            <input type="number" placeholder="Number of Tickets" required>

            <button class="btn">Confirm Booking</button>

        </form>

    </section>

    <!-- Footer -->

    <footer>
        <p>© 2026 MovieZone. All Rights Reserved.</p>
    </footer>

</body>
</html>
